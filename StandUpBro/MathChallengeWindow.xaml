<Window x:Class="StandUpBro.MathChallengeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stand Up, Bro!"
        Width="380" Height="300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <!-- Outer border with rounded corners and shadow -->
    <Border CornerRadius="16"
            Background="{StaticResource BgDarkBrush}"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="2"
            Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0"
                              Color="{StaticResource PrimaryColor}" Opacity="0.4" />
        </Border.Effect>

        <Grid Margin="28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="🧍 Stand Up, Bro!"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6" />

            <!-- Subtitle -->
            <TextBlock Grid.Row="1"
                       Text="Solve this to dismiss:"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

            <!-- Math problem -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgMediumBrush}"
                    CornerRadius="10" Padding="20,12"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16">
                <TextBlock x:Name="ProblemLabel"
                           Text="12 + 15 ="
                           FontSize="32" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           FontFamily="Consolas" />
            </Border>

            <!-- Answer input -->
            <Grid Grid.Row="3" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="AnswerInput"
                         Grid.Column="0"
                         Style="{StaticResource ModernTextBox}"
                         FontSize="18"
                         TextAlignment="Center"
                         Margin="0,0,10,0" />

                <Button x:Name="CheckButton"
                        Grid.Column="1"
                        Content="Check"
                        Style="{StaticResource ModernButton}"
                        Width="90"
                        Click="CheckButton_Click" />
            </Grid>

            <!-- Feedback label -->
            <TextBlock x:Name="FeedbackLabel"
                       Grid.Row="4"
                       Text=""
                       FontSize="13"
                       Foreground="{StaticResource DangerBrush}"
                       HorizontalAlignment="Center" />
        </Grid>
    </Border>
</Window>
