<Window x:Class="StandUpBro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StandUpBro"
        Width="420" Height="520"
        MinWidth="320" MinHeight="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource BgDarkBrush}">

    <!-- Viewbox wraps all content so the entire UI scales uniformly when resized -->
    <Viewbox Stretch="Uniform" StretchDirection="Both">
        <Grid Width="420" Height="500">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ Header ═══ -->
            <Border Grid.Row="0" Padding="0,30,0,10">
                <StackPanel HorizontalAlignment="Center">
                    <!-- App icon emoji -->
                    <TextBlock Text="🧍" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="StandUpBro"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Your friendly stand-up reminder"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- ═══ Center content ═══ -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                <!-- Timer display -->
                <Border Background="{StaticResource BgMediumBrush}"
                        CornerRadius="16" Padding="40,24" Margin="0,0,0,24"
                        HorizontalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="TimerDisplay"
                                   Text="45:00"
                                   FontSize="56" FontWeight="Light"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   FontFamily="Consolas" />
                        <TextBlock x:Name="StatusLabel"
                                   Text="Ready"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Interval setting -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="Interval (minutes):"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBox x:Name="IntervalInput"
                             Text="45"
                             Width="70"
                             TextAlignment="Center"
                             Style="{StaticResource ModernTextBox}"
                             VerticalAlignment="Center" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="StartButton"
                            Content="▶  Start"
                            Style="{StaticResource ModernButton}"
                            Width="140"
                            Click="StartButton_Click"
                            Margin="0,0,12,0" />
                    <Button x:Name="StopButton"
                            Content="■  Stop"
                            Style="{StaticResource DangerButton}"
                            Width="140"
                            Click="StopButton_Click"
                            IsEnabled="False" />
                </StackPanel>
            </StackPanel>

            <!-- ═══ Footer ═══ -->
            <Border Grid.Row="2" Padding="16,12">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Minimizes to system tray • Right-click tray icon for options"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                        <CheckBox x:Name="AutostartCheckBox"
                                  Content="Launch on Windows startup"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  FontSize="11"
                                  Checked="AutostartCheckBox_Changed"
                                  Unchecked="AutostartCheckBox_Changed"
                                  VerticalContentAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Viewbox>
</Window>
